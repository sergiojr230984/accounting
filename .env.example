# --- Required ---

# Postgres connection string. On Railway this is auto-provided via the
# Postgres add-on as DATABASE_URL.
DATABASE_URL="postgresql://postgres:password@localhost:5432/accounting_db"

# NextAuth session signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-min-32-chars-change-in-production"

# --- Recommended ---

# Anthropic key for AI invoice extraction (Claude). Without this, the
# "Import from file" feature on new-invoice degrades gracefully.
ANTHROPIC_API_KEY=""

# Public base URL used to build payment links in outgoing emails. If unset,
# the server falls back to the request's own host.
APP_URL="https://lacuevitafurniture.com"

# File uploads (absolute path to uploads directory).
UPLOAD_DIR="./public/uploads"

# --- Optional: email ---

# Resend API key. Without it the Send button returns a friendly error and
# the Print PDF / Copy-link flows still work.
RESEND_API_KEY=""
EMAIL_FROM="La Cuevita Accounting <onboarding@resend.dev>"

# --- Optional: monitoring ---

# Sentry DSNs — set the server one privately; the public one is exposed to
# browsers and may be empty if you only want server-side error capture.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
