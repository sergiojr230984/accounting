# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/accounting_db"

# NextAuth
AUTH_SECRET="your-secret-key-min-32-chars-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# File uploads (absolute path to uploads directory)
UPLOAD_DIR="./public/uploads"

# Anthropic API — for AI invoice data extraction (get key at console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-..."

# ── WhatsApp Business Cloud API (Meta) — CRM de leads ──────────────────────
# Token permanente del System User (Meta Business Suite → Usuarios del sistema)
WHATSAPP_TOKEN=""
# phone_number_id por defecto desde el que se envían mensajes
WHATSAPP_PHONE_NUMBER_ID=""
# Cadena secreta que tú inventas; debe coincidir con la que pongas en Meta al
# configurar el webhook (Verify Token)
WHATSAPP_VERIFY_TOKEN="cuevita-verify-token"
# Versión del Graph API (opcional, default v21.0)
WHATSAPP_API_VERSION="v21.0"
