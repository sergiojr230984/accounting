# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/accounting_db"

# NextAuth
AUTH_SECRET="your-secret-key-min-32-chars-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# File uploads (absolute path to uploads directory)
UPLOAD_DIR="./public/uploads"

# Anthropic API — for AI invoice data extraction
ANTHROPIC_API_KEY="sk-ant-..."

# ── WhatsApp Business Cloud API (Meta) ─────────────────────────────────────
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="cuevita-verify-token"
WHATSAPP_API_VERSION="v21.0"

# ── TIN Encryption (AES-256-GCM) ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TIN_ENCRYPTION_KEY=""

# ── Backups ─────────────────────────────────────────────────────────────────
# Local directory where backup .json.gz files are stored
BACKUP_DIR="./backups"

# Optional: S3-compatible object storage (leave blank to skip cloud upload)
BACKUP_S3_BUCKET=""
BACKUP_S3_ENDPOINT="https://s3.amazonaws.com"
BACKUP_S3_REGION="us-east-1"
BACKUP_S3_ACCESS_KEY=""
BACKUP_S3_SECRET_KEY=""

# Alert email for failed backups (leave blank to skip)
BACKUP_ALERT_EMAIL=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
