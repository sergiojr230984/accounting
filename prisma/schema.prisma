generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  SALES
}

// ── CRM enums ──────────────────────────────────────────────────────────────

enum LeadStatus {
  NEW // Lead recién entrado, sin contactar
  CONTACTED // Ya se le escribió/llamó al menos una vez
  FOLLOW_UP // En seguimiento activo
  CLOSED // Venta cerrada (ganado)
  LOST // Perdido / no interesado
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

enum LeadSource {
  WHATSAPP
  MANUAL
  REFERRAL
  FACEBOOK
  INSTAGRAM
  WEBSITE
  OTHER
}

enum MessageDirection {
  INBOUND // Cliente → vendedora
  OUTBOUND // Vendedora → cliente
}

enum AssignmentMode {
  MANUAL // El admin asigna a mano
  ROUND_ROBIN // Rotación automática entre vendedoras activas
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum SupplierCategory {
  COGS
  SERVICES_EXPENSE
  OPERATING_EXPENSE
  OTHER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MANAGER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── CRM: campos de vendedora ──
  // Número de WhatsApp visible de la vendedora (formato E.164, ej: +5215512345678)
  whatsappNumber        String?
  // ID del número de teléfono en la WhatsApp Cloud API de Meta. Se usa en el
  // webhook para saber a QUÉ vendedora le escribió el cliente.
  whatsappPhoneNumberId String? @unique

  // Relaciones CRM
  assignedLeads       Lead[]           @relation("AssignedLeads")
  assignmentsReceived LeadAssignment[] @relation("AssignmentTo")
  assignmentsMade     LeadAssignment[] @relation("AssignmentBy")
}

model Customer {
  id        String            @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  invoices  CustomerInvoice[]
}

model Supplier {
  id        String            @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  invoices  SupplierInvoice[]
}

model CustomerInvoice {
  id            String                @id @default(cuid())
  invoiceNumber String
  customerId    String
  customer      Customer              @relation(fields: [customerId], references: [id])
  invoiceDate   DateTime
  dueDate       DateTime
  subtotal      Decimal               @db.Decimal(15, 2)
  taxAmount     Decimal               @default(0) @db.Decimal(15, 2)
  totalAmount   Decimal               @db.Decimal(15, 2)
  paidAmount    Decimal               @default(0) @db.Decimal(15, 2)
  paymentStatus PaymentStatus         @default(UNPAID)
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  items         CustomerInvoiceItem[]
  payments      Payment[]
  files         UploadedFile[]

  @@unique([invoiceNumber, customerId])
}

model CustomerInvoiceItem {
  id          String          @id @default(cuid())
  invoiceId   String
  invoice     CustomerInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal         @db.Decimal(15, 4)
  unitPrice   Decimal         @db.Decimal(15, 2)
  taxRate     Decimal         @default(0) @db.Decimal(5, 4)
  lineTotal   Decimal         @db.Decimal(15, 2)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model SupplierInvoice {
  id            String                @id @default(cuid())
  invoiceNumber String
  supplierId    String
  supplier      Supplier              @relation(fields: [supplierId], references: [id])
  invoiceDate   DateTime
  dueDate       DateTime?
  category      SupplierCategory
  subtotal      Decimal               @db.Decimal(15, 2)
  taxAmount     Decimal               @default(0) @db.Decimal(15, 2)
  totalAmount   Decimal               @db.Decimal(15, 2)
  paidAmount    Decimal               @default(0) @db.Decimal(15, 2)
  paymentStatus PaymentStatus         @default(UNPAID)
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  items         SupplierInvoiceItem[]
  payments      Payment[]
  files         UploadedFile[]

  @@unique([invoiceNumber, supplierId])
}

model SupplierInvoiceItem {
  id          String          @id @default(cuid())
  invoiceId   String
  invoice     SupplierInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal         @db.Decimal(15, 4)
  unitCost    Decimal         @db.Decimal(15, 2)
  taxRate     Decimal         @default(0) @db.Decimal(5, 4)
  lineTotal   Decimal         @db.Decimal(15, 2)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Payment {
  id                String           @id @default(cuid())
  amount            Decimal          @db.Decimal(15, 2)
  paymentDate       DateTime
  notes             String?
  customerInvoiceId String?
  customerInvoice   CustomerInvoice? @relation(fields: [customerInvoiceId], references: [id])
  supplierInvoiceId String?
  supplierInvoice   SupplierInvoice? @relation(fields: [supplierInvoiceId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model UploadedFile {
  id                String           @id @default(cuid())
  originalName      String
  storedName        String
  mimeType          String
  size              Int
  path              String
  customerInvoiceId String?
  customerInvoice   CustomerInvoice? @relation(fields: [customerInvoiceId], references: [id])
  supplierInvoiceId String?
  supplierInvoice   SupplierInvoice? @relation(fields: [supplierInvoiceId], references: [id])
  createdAt         DateTime         @default(now())
}

// ── CRM: Leads de WhatsApp ──────────────────────────────────────────────────

/// Un lead = un prospecto que escribió por WhatsApp (o se cargó a mano).
/// El teléfono es único para evitar duplicados: si el mismo número escribe
/// otra vez, se reutiliza el lead existente y solo se agrega el mensaje.
model Lead {
  id    String @id @default(cuid())
  name  String
  phone String @unique // WhatsApp del cliente, formato E.164

  status   LeadStatus   @default(NEW)
  priority LeadPriority @default(MEDIUM)
  source   LeadSource   @default(WHATSAPP)

  // Vendedora asignada (puede quedar sin asignar hasta que el admin la asigne)
  assignedToId String?
  assignedTo   User?   @relation("AssignedLeads", fields: [assignedToId], references: [id])

  notes           String? // Notas internas del equipo
  entryDate       DateTime  @default(now()) // Fecha de entrada del lead
  lastMessageAt   DateTime? // Fecha del último mensaje (entrante o saliente)
  lastMessageText String? // Vista previa del último mensaje recibido
  nextFollowUpAt  DateTime? // Próxima fecha de seguimiento

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages    LeadMessage[]
  assignments LeadAssignment[]

  @@index([assignedToId])
  @@index([status])
  @@index([entryDate])
}

/// Cada mensaje del historial de conversación de un lead.
model LeadMessage {
  id          String           @id @default(cuid())
  leadId      String
  lead        Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  direction   MessageDirection
  body        String
  // ID del mensaje en WhatsApp (para deduplicar webhooks reenviados por Meta)
  waMessageId String?          @unique
  fromNumber  String?
  toNumber    String?
  timestamp   DateTime         @default(now())
  createdAt   DateTime         @default(now())

  @@index([leadId])
}

/// Historial de cambios de asignación (auditoría de quién pasó el lead a quién).
model LeadAssignment {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Vendedora anterior (null si el lead no estaba asignado)
  fromUserName String?
  // Vendedora nueva
  toUserId     String
  toUser       User    @relation("AssignmentTo", fields: [toUserId], references: [id])

  // Quién hizo el cambio (null si fue el sistema, ej. round-robin del webhook)
  changedById String?
  changedBy   User?   @relation("AssignmentBy", fields: [changedById], references: [id])

  reason    String? // "manual", "round_robin", "reassign", etc.
  createdAt DateTime @default(now())

  @@index([leadId])
}

/// Configuración global del CRM (fila única id="singleton").
model CrmSetting {
  id                String         @id @default("singleton")
  assignmentMode    AssignmentMode @default(ROUND_ROBIN)
  // Puntero de rotación para el round-robin de asignación automática
  lastRotationIndex Int            @default(0)
  updatedAt         DateTime       @updatedAt
}
