generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  SALES
}

enum LeadStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  CLOSED
  LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

enum LeadSource {
  WHATSAPP
  MANUAL
  REFERRAL
  FACEBOOK
  INSTAGRAM
  WEBSITE
  OTHER
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum AssignmentMode {
  MANUAL
  ROUND_ROBIN
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum SupplierCategory {
  COGS
  SERVICES_EXPENSE
  OPERATING_EXPENSE
  OTHER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MANAGER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  whatsappNumber        String?
  whatsappPhoneNumberId String? @unique

  assignedLeads       Lead[]           @relation("AssignedLeads")
  assignmentsReceived LeadAssignment[] @relation("AssignmentTo")
  assignmentsMade     LeadAssignment[] @relation("AssignmentBy")
}

model Customer {
  id        String            @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  invoices  CustomerInvoice[]
}

model Supplier {
  id        String            @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  invoices  SupplierInvoice[]

  is1099Contractor Boolean @default(false)
  taxId            String?
  taxIdType        String?
  legalName        String?
  businessAddress  String?
  w9OnFile         Boolean @default(false)
  w9FilePath       String?
  default1099Box   String? @default("NEC_BOX_1")
}

model CustomerInvoice {
  id            String                @id @default(cuid())
  invoiceNumber String
  customerId    String
  customer      Customer              @relation(fields: [customerId], references: [id])
  invoiceDate   DateTime
  dueDate       DateTime
  subtotal      Decimal               @db.Decimal(15, 2)
  taxAmount     Decimal               @default(0) @db.Decimal(15, 2)
  totalAmount   Decimal               @db.Decimal(15, 2)
  paidAmount    Decimal               @default(0) @db.Decimal(15, 2)
  paymentStatus PaymentStatus         @default(UNPAID)
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  items         CustomerInvoiceItem[]
  payments      Payment[]
  files         UploadedFile[]

  @@unique([invoiceNumber, customerId])
}

model CustomerInvoiceItem {
  id          String          @id @default(cuid())
  invoiceId   String
  invoice     CustomerInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal         @db.Decimal(15, 4)
  unitPrice   Decimal         @db.Decimal(15, 2)
  taxRate     Decimal         @default(0) @db.Decimal(5, 4)
  lineTotal   Decimal         @db.Decimal(15, 2)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model SupplierInvoice {
  id                 String                @id @default(cuid())
  invoiceNumber      String
  supplierId         String
  supplier           Supplier              @relation(fields: [supplierId], references: [id])
  invoiceDate        DateTime
  dueDate            DateTime?
  category           SupplierCategory
  subtotal           Decimal               @db.Decimal(15, 2)
  taxAmount          Decimal               @default(0) @db.Decimal(15, 2)
  totalAmount        Decimal               @db.Decimal(15, 2)
  paidAmount         Decimal               @default(0) @db.Decimal(15, 2)
  paymentStatus      PaymentStatus         @default(UNPAID)
  notes              String?
  customerInvoiceRef String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  items              SupplierInvoiceItem[]
  payments           Payment[]
  files              UploadedFile[]

  @@unique([invoiceNumber, supplierId])
}

model SupplierInvoiceItem {
  id          String          @id @default(cuid())
  invoiceId   String
  invoice     SupplierInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal         @db.Decimal(15, 4)
  unitCost    Decimal         @db.Decimal(15, 2)
  taxRate     Decimal         @default(0) @db.Decimal(5, 4)
  lineTotal   Decimal         @db.Decimal(15, 2)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Payment {
  id                String           @id @default(cuid())
  amount            Decimal          @db.Decimal(15, 2)
  paymentDate       DateTime
  notes             String?
  paymentMethod     String?
  customerInvoiceId String?
  customerInvoice   CustomerInvoice? @relation(fields: [customerInvoiceId], references: [id])
  supplierInvoiceId String?
  supplierInvoice   SupplierInvoice? @relation(fields: [supplierInvoiceId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model UploadedFile {
  id                String           @id @default(cuid())
  originalName      String
  storedName        String
  mimeType          String
  size              Int
  path              String
  customerInvoiceId String?
  customerInvoice   CustomerInvoice? @relation(fields: [customerInvoiceId], references: [id])
  supplierInvoiceId String?
  supplierInvoice   SupplierInvoice? @relation(fields: [supplierInvoiceId], references: [id])
  createdAt         DateTime         @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  actorUserId String?
  actorName   String
  actorRole   String
  action      String
  entityType  String
  entityId    String?
  entityLabel String
  changes     Json?
  ipAddress   String
  userAgent   String

  @@index([timestamp])
  @@index([actorUserId])
  @@index([entityType])
  @@index([action])
}

model BackupLog {
  id            String    @id @default(cuid())
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  status        String
  type          String
  sizeBytes     BigInt?
  location      String?
  errorMessage  String?
  triggeredById String?

  @@index([startedAt])
  @@index([status])
}

model Lead {
  id    String @id @default(cuid())
  name  String
  phone String @unique

  status   LeadStatus   @default(NEW)
  priority LeadPriority @default(MEDIUM)
  source   LeadSource   @default(WHATSAPP)

  assignedToId String?
  assignedTo   User?   @relation("AssignedLeads", fields: [assignedToId], references: [id])

  notes           String?
  entryDate       DateTime  @default(now())
  lastMessageAt   DateTime?
  lastMessageText String?
  nextFollowUpAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages    LeadMessage[]
  assignments LeadAssignment[]

  @@index([assignedToId])
  @@index([status])
  @@index([entryDate])
}

model LeadMessage {
  id          String           @id @default(cuid())
  leadId      String
  lead        Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  direction   MessageDirection
  body        String
  waMessageId String?          @unique
  fromNumber  String?
  toNumber    String?
  timestamp   DateTime         @default(now())
  createdAt   DateTime         @default(now())

  @@index([leadId])
}

model LeadAssignment {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  fromUserName String?
  toUserId     String
  toUser       User    @relation("AssignmentTo", fields: [toUserId], references: [id])

  changedById String?
  changedBy   User?   @relation("AssignmentBy", fields: [changedById], references: [id])

  reason    String?
  createdAt DateTime @default(now())

  @@index([leadId])
}

model CrmSetting {
  id                String         @id @default("singleton")
  assignmentMode    AssignmentMode @default(ROUND_ROBIN)
  lastRotationIndex Int            @default(0)
  updatedAt         DateTime       @updatedAt
}
